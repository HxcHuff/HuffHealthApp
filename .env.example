DATABASE_URL="postgresql://user:password@localhost:5432/huffhealthapp?schema=public"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HuffHealth"
NEXT_PUBLIC_APP_TAGLINE="CRM & Client Portal"

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxx"

# Lead Ingest API — Bearer token for POST /api/leads/ingest
# Generate with: openssl rand -hex 32
LEAD_INGEST_SECRET=""

# Lead Router — fires on every new lead from the ingest endpoint.
# Set LEAD_PIPELINE_DRY_RUN=true in dev/staging to skip real Twilio sends.
LEAD_PIPELINE_DRY_RUN="true"
ADMIN_NOTIFY_PHONE=""             # E.164, e.g. +18635551234 — receives instant "new lead" alerts
AGENT_DISPLAY_NAME=""             # e.g. "David at HuffHealth" — used in speed-to-lead SMS
LEAD_ROUTER_WEBHOOK_URL=""        # Optional: POST classified lead JSON to this URL
LEAD_ROUTER_WEBHOOK_SECRET=""     # Optional: sent as x-webhook-secret header

# Twilio — required for SMS. Skipped automatically in DRY_RUN.
# A2P 10DLC brand+campaign registration is required for US business SMS.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""             # E.164, the registered Twilio number (legacy sms.ts)
TWILIO_PHONE_NUMBER=""            # E.164, used by Conversations API (defaults to TWILIO_FROM_NUMBER)
TWILIO_CONVERSATIONS_SERVICE_SID="" # ISxxxxxxxx — Conversations service SID
TWILIO_MESSAGING_SERVICE_SID=""   # MGxxxxxxxx — Messaging service for SMS routing
TWILIO_WEBHOOK_BASE_URL=""        # Public base URL for webhook callbacks (e.g. https://app.example.com)

# Facebook Integration
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_VERIFY_TOKEN=""
ENCRYPTION_KEY=""
DRIP_WEBHOOK_SECRET=""
DRIP_ENGINE_MODE="internal"
DRIP_ENGINE_API_KEY=""
DRIP_ENGINE_URL=""
NEXT_PUBLIC_DRIP_ENGINE_URL=""

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Temporary CRM Drop Box storage location (auto-purged after 96h)
DROPBOX_STORAGE_DIR=""

HEALTHSHERPA_MEDICARE_BASE_URL="https://api.medicare.healthsherpa.com"
HEALTHSHERPA_MEDICARE_API_KEY=""
HEALTHSHERPA_MEDICARE_AGENT_EMAIL=""

NEXT_PUBLIC_UI_V2_ENABLED="false"
